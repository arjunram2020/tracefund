# Deployer private key for PUBLIC networks (Base / Ethereum). Never commit a real key.
# Local development does not need this — Hardhat provides funded test accounts.
DEPLOYER_PRIVATE_KEY=

# Optional RPC overrides (sensible public defaults are used if unset).
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
MAINNET_RPC_URL=https://eth.llamarpc.com

# Optional: contract verification on Basescan / Etherscan.
BASESCAN_API_KEY=
ETHERSCAN_API_KEY=
