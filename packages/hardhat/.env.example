# Deployer private key for PUBLIC networks (Base). Never commit a real key.
# Local development does not need this — Hardhat provides funded test accounts.
DEPLOYER_PRIVATE_KEY=

# Optional donor keys used ONLY by `yarn seed` on public networks (e.g. Base),
# where the deployer is the only signer. Each must hold a little ETH for gas
# plus enough USDC for its donation (donations settle in USDC, not ETH).
# Not needed on the local Hardhat node. Never commit real keys.
DONOR_A_KEY=
DONOR_B_KEY=

# Optional RPC overrides (sensible public defaults are used if unset).
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Optional: contract verification on Basescan.
BASESCAN_API_KEY=
