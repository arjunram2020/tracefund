# Covenant frontend configuration — copy to `.env.local` and fill in.
#
# ============================================================================
#  ⚠  EVERY VARIABLE HERE IS PUBLIC.
#  Anything prefixed NEXT_PUBLIC_ is inlined into the JavaScript bundle that
#  ships to every visitor's browser. NEVER put a secret here: no private keys,
#  no API secrets, no admin tokens, no database URLs. Server-only secrets
#  (deployer keys, indexer ADMIN_TOKEN / EVIDENCE_WRITE_TOKEN / EVIDENCE_ENC_KEY)
#  live in the hardhat and indexer packages, NOT in this file.
# ============================================================================

# Which chain the UI targets by default. 8453 = Base mainnet, 84532 = Base
# Sepolia, 31337 = local Hardhat.
NEXT_PUBLIC_DEFAULT_CHAIN_ID=8453

# WalletConnect project ID (from https://cloud.walletconnect.com). This value is
# designed to be public — it identifies your app to the WalletConnect relay and
# is safe to expose. Required only for mobile / cross-device wallet connections;
# a local injected wallet (MetaMask) works without it.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# RPC endpoints the BROWSER uses to read the chain.
#
#   ⚠  These URLs are public. Do NOT paste a provider URL that embeds a secret
#   API key (e.g. https://…/v2/<SECRET>) — that key would be exposed to every
#   visitor. Use either:
#     • a public RPC (https://mainnet.base.org), or
#     • a provider endpoint whose key is domain/referrer-restricted, or
#     • your own read-only proxy that injects the key server-side.
#
# Leave unset to use the built-in public RPCs (rate-limited but keyless).
NEXT_PUBLIC_BASE_RPC_URL=
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=

# Read-only Ethereum mainnet RPC, used ONLY for ENS name resolution. Same
# public-URL warning as above. Optional.
NEXT_PUBLIC_MAINNET_RPC_URL=

# Base URL of the Covenant indexer/evidence API (see packages/indexer). Public
# by nature — it's the API the browser calls. Example: https://your-host/api
# Leave unset to disable indexer-backed history and the evidence registry.
NEXT_PUBLIC_INDEXER_URL=

# ============================================================================
#  SERVER-ONLY variables (below this line). These are NOT prefixed
#  NEXT_PUBLIC_, so they stay on the server and are never inlined into the
#  browser bundle. Safe to hold secrets here.
# ============================================================================

# Base URL the SERVER uses to reach the indexer, for the authenticated evidence
# write proxy (app/api/evidence/[locator]). Optional — falls back to
# NEXT_PUBLIC_INDEXER_URL when unset. Set this only if the server should reach
# the indexer at a different (e.g. internal) address than the browser does.
INDEXER_URL=

# The indexer's evidence write bearer token (must equal EVIDENCE_WRITE_TOKEN in
# packages/indexer/.env). The write proxy attaches it server-side so the browser
# never sees it. Required for evidence uploads to reach a production indexer;
# without it the proxy forwards unauthenticated and a token-protected indexer
# will 401 the write.
EVIDENCE_WRITE_TOKEN=
