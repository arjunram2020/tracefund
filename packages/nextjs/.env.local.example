# Optional: WalletConnect Cloud project id (https://cloud.walletconnect.com).
# Local development with an injected wallet (MetaMask) works without it, but
# setting a real id enables WalletConnect / mobile wallets.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Optional: override the default target chain id shown in the UI.
# 31337 = local Hardhat, 8453 = Base Mainnet, 84532 = Base Sepolia.
NEXT_PUBLIC_DEFAULT_CHAIN_ID=31337
