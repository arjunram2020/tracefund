# Which chain the UI reads from and asks wallets to use.
# 8453 = Base Mainnet, 84532 = Base Sepolia, 31337 = local Hardhat.
# For the two-device (shared Base Mainnet) demo, set this to 8453.
NEXT_PUBLIC_DEFAULT_CHAIN_ID=8453

# WalletConnect Cloud project id (https://cloud.walletconnect.com).
# A browser-extension MetaMask works without it, but a REAL id is required for a
# second phone/laptop to connect to the hosted demo via WalletConnect / QR.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Optional dedicated RPC endpoints. The built-in public RPCs work but are
# rate-limited; for a hosted multi-device demo point Base at a dedicated
# endpoint (Alchemy/Infura/QuickNode) so reads stay reliable across devices.
NEXT_PUBLIC_BASE_RPC_URL=
# NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=
# NEXT_PUBLIC_MAINNET_RPC_URL=
