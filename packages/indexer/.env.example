# Copy this file to .env and fill in values.

# Your Base Mainnet RPC URL — how the indexer "talks to the blockchain".
# NOTE on getLogs limits (the real cost of indexing):
#   - Alchemy/Infura FREE tier cap eth_getLogs to a ~10-block range -> backfill
#     would need tens of thousands of calls. Avoid for backfill.
#   - The public RPC below allows 10,000-block ranges -> ~75 calls total. Good default.
#   - A paid RPC plan removes the cap entirely (the production answer).
BASE_RPC_URL=https://mainnet.base.org

# The deployed Covenant contract on Base Mainnet — copy the address and deploy
# block that `yarn deploy:base` prints (also recorded in
# packages/nextjs/contracts/deployedContracts.json under "8453").
CONTRACT_ADDRESS=0xYourDeployedCovenantAddress

# The block the contract was deployed at — where we start scanning history.
DEPLOY_BLOCK=0

# Port the API server listens on.
PORT=4000

# Where the SQLite database file lives.
DB_PATH=./covenant.db

# How many blocks to request per getLogs call during backfill.
# Lower this if your RPC provider rejects large ranges.
CHUNK_SIZE=5000

# How often (ms) to poll for new events after backfill is done.
POLL_INTERVAL_MS=12000

# ---------------------------------------------------------------------------
# Security (all optional — safe permissive defaults for local dev; SET THESE IN
# PRODUCTION). The server logs a [security] warning at startup for any unset one.
# ---------------------------------------------------------------------------

# Comma-separated CORS allowlist for the API. Set this to your frontend
# origin(s) in production. When unset, all origins are allowed (dev only).
# e.g. ALLOWED_ORIGINS=https://app.covenant.example,https://covenant.example
ALLOWED_ORIGINS=

# Bearer token required to WRITE evidence manifests (PUT /evidence/:hash).
# Generate a long random value, e.g. `openssl rand -hex 32`. When unset,
# evidence writes are unauthenticated (dev only).
EVIDENCE_WRITE_TOKEN=

# When "true", evidence READS (GET /evidence/:hash) also require the write
# token above — "confidential mode" for genuinely private proof packages.
# Leave unset/false to keep the capability-by-hash read model.
EVIDENCE_PROTECTED=false

# Bearer token for the admin-only audit endpoint (GET /audit). When unset, the
# endpoint returns 404 (disabled). Generate with `openssl rand -hex 32`.
ADMIN_TOKEN=

# Salt for one-way hashing of IP/token fingerprints in the audit log, so raw
# IPs and tokens are never stored. Set a stable random value in production;
# defaults to the contract address if unset. Rotating it resets fingerprint
# correlation (old rows won't match new ones).
AUDIT_SALT=

# Optional 32-byte key to ENCRYPT EVIDENCE AT REST (AES-256-GCM). Defense in
# depth: a stolen DB file or backup is useless without it. Accepts 64 hex chars
# or base64. Generate with `openssl rand -hex 32`. Unset = store as received
# (dev). Back this key up securely and separately from the database — losing it
# makes encrypted rows unreadable. See docs/EVIDENCE_SECURITY_MODEL.md.
EVIDENCE_ENC_KEY=

# Set NODE_ENV=production on the server. In production the indexer FAILS TO
# START if ALLOWED_ORIGINS, EVIDENCE_WRITE_TOKEN, or ADMIN_TOKEN are unset
# (fail-closed) instead of silently running open. Leave unset for local dev.
# NODE_ENV=production

# Rate limiting (per client IP, fixed window). Defaults shown; tune per traffic.
#   RATE_LIMIT_WINDOW_MS   — window length in ms (default 60000)
#   RATE_LIMIT_MAX         — max requests per window on normal routes (default 300)
#   RATE_LIMIT_SENSITIVE_MAX — stricter cap on evidence writes + /audit (default 30)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
RATE_LIMIT_SENSITIVE_MAX=30
