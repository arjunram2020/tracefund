# dependencies
node_modules
.yarn/cache
.pnp.*

# hardhat
packages/hardhat/artifacts
packages/hardhat/cache
packages/hardhat/typechain-types
packages/hardhat/coverage
packages/hardhat/coverage.json

# next.js
packages/nextjs/.next
packages/nextjs/out
packages/nextjs/build

# env — ignore EVERY env file (any name, any package) except the committed
# *.example templates. This covers .env, .env.local, .env.production,
# .env.development, .env.staging, etc. so real secrets can never be committed.
.env
.env.*
!.env.example
!*.env.example

# indexer sqlite artifacts (wherever the indexer was launched from)
covenant.db
covenant.db-shm
covenant.db-wal
covenant.db.pre-restore-*

# backup artifacts — NEVER commit these: they contain evidence (even encrypted)
# and the access audit log. Store them out-of-band per docs/BACKUP_RECOVERY.md.
backups/
*.db.gz
*.db.gz.sha256

# misc
.DS_Store
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
