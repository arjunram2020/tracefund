{
  "name": "covenant",
  "version": "0.1.0",
  "private": true,
  "description": "Covenant — milestone-based crowdfunding with enforced accountability on Ethereum (Base).",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "chain": "yarn workspace @covenant/hardhat chain",
    "compile": "yarn workspace @covenant/hardhat compile",
    "test": "yarn workspace @covenant/hardhat test",
    "deploy": "yarn workspace @covenant/hardhat deploy",
    "deploy:baseSepolia": "yarn workspace @covenant/hardhat deploy:baseSepolia",
    "deploy:base": "yarn workspace @covenant/hardhat deploy:base",
    "seed": "yarn workspace @covenant/hardhat seed",
    "start": "yarn workspace @covenant/nextjs dev",
    "frontend": "yarn workspace @covenant/nextjs dev",
    "loadtest:seed": "yarn workspace @covenant/loadtest seed",
    "loadtest:actors": "yarn workspace @covenant/loadtest actors",
    "loadtest:web": "yarn workspace @covenant/loadtest web",
    "loadtest:browser": "yarn workspace @covenant/loadtest browser"
  },
  "packageManager": "yarn@1.22.22",
  "resolutions": {
    "qr": "0.5.5"
  }
}
